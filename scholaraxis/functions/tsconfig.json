{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "lib": [
      "es2022"
    ],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "lib",
    "sourceMap": true
  },
  "compileOnSave": true,
  "include": [
    "src"
  ]
}
